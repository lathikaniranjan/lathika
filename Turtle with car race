from turtle import Screen, Turtle

FONT = ("Courier", 24, "normal")


class Scoreboard(Turtle):
    def __init__(self):
        super().__init__()
        self.level = 1
        self.hideturtle()
        self.penup()
        self.update()





    def update(self):
        self.goto(-280, 250)
        self.write(f"Level: {self.level}", align="left", font=FONT)



    def level_up(self):

        self.clear()
        self.level+=1
        self.update()
